// Общий модуль расширения для рабочего места бригадиров.
// Если в вашей базе документ называется не "ЗаказНаСборку",
// а иначе, замените имя документа в тексте запроса.

&НаСервереБезКонтекста
Функция ПолучитьСписокЗаказовБригадиров() Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
"ВЫБРАТЬ
|   Заказы.Ссылка КАК Ссылка,
|   Заказы.Номер КАК Номер,
|   Заказы.Дата КАК Дата,
|   Заказы.Комментарий КАК КомментарийМенеджера,
|   Заказы.КомментарийБригадиров КАК КомментарийБригадиров
|ИЗ
|   Документ.ЗаказНаСборку КАК Заказы
|ГДЕ
|   Заказы.ПометкаБригадиров
|УПОРЯДОЧИТЬ ПО
|   Заказы.Дата УБЫВ,
|   Заказы.Номер УБЫВ";

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьКомментарийБригадиров(СсылкаЗаказа, КомментарийБригадиров) Экспорт

    Если Не ЗначениеЗаполнено(СсылкаЗаказа) Тогда
        Возврат;
    КонецЕсли;

    Если КомментарийБригадиров = Неопределено Тогда
        КомментарийБригадиров = "";
    КонецЕсли;

    ЗаказОбъект = СсылкаЗаказа.ПолучитьОбъект();
    ЗаказОбъект.КомментарийБригадиров = Лев(СокрЛП(КомментарийБригадиров), 500);
    ЗаказОбъект.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СнятьПометкуБригадиров(СсылкаЗаказа) Экспорт

    Если Не ЗначениеЗаполнено(СсылкаЗаказа) Тогда
        Возврат;
    КонецЕсли;

    ЗаказОбъект = СсылкаЗаказа.ПолучитьОбъект();
    ЗаказОбъект.ПометкаБригадиров = Ложь;
    ЗаказОбъект.Записать();

КонецПроцедуры
